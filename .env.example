# ─── Service auth (website backend giữ secret này, KHÔNG để lộ ra JS trình duyệt) ───
SERVICE_API_KEY=change-me-to-a-long-random-string

# ─── Provider primary: 9Router (free, Sonnet 4.5 đã validate) ───
NINEROUTER_URL=http://18.141.175.151:20128/v1
NINEROUTER_KEY=

# ─── Provider failover: OpenAI direct (auto-cache, hiếm khi chạy) ───
OPENAI_API_KEY=
OPENAI_FAILOVER_MODEL=gpt-4o

# ─── Generation params (giữ y demo đã validate) ───
DEFAULT_MODEL=sonnet-4.5
TEMPERATURE=0.2
MAX_TOKENS=1500

# ─── Limits / bảo mật request ───
MAX_HISTORY_MSGS=40
MAX_MESSAGE_CHARS=8000
RATE_LIMIT_PER_MIN=30
TTFT_TIMEOUT_S=15
READ_TIMEOUT_S=120
